---
import { type Lang } from "../i18n/ui";
interface Props { lang: Lang; }
const { lang } = Astro.props;

const copy = {
  es: {
    heading: "Así se ve RumboDesk",
    sub: "Tres vistas, una operación bajo control.",
    salesLabel: "Ventas del mes",
    salesDelta: "▲ 18% vs. mes anterior",
    activeLabel: "Reservas activas",
    activeDelta: "6 ingestiones pendientes",
    trendLabel: "Tendencia mes a mes",
    suppliersTitle: "Proveedores",
    dashCaptionLead: "Dashboard.",
    dashCaption: "Ventas del mes, tendencia mes a mes, ingestiones pendientes, vencimientos próximos.",
    supCaptionLead: "Proveedores.",
    supCaption: "Catálogo unificado, ubicación, IATA y categoría. Sin duplicados.",
    proveedores: [
      { flag: "🇲🇽", name: "Aeroméxico", iata: "AM", cat: "Aerolínea" },
      { flag: "🇪🇸", name: "Iberia", iata: "IB", cat: "Aerolínea" },
      { flag: "🇪🇸", name: "RIU Hotels", iata: "—", cat: "Hotelería" },
      { flag: "🇦🇷", name: "Despegar", iata: "—", cat: "OTA" },
      { flag: "🇵🇪", name: "Costamar", iata: "—", cat: "Mayorista" },
    ],
  },
  en: {
    heading: "This is what RumboDesk looks like",
    sub: "Three views, one operation under control.",
    salesLabel: "Sales this month",
    salesDelta: "▲ 18% vs. last month",
    activeLabel: "Active bookings",
    activeDelta: "6 pending ingestions",
    trendLabel: "Month-over-month trend",
    suppliersTitle: "Suppliers",
    dashCaptionLead: "Dashboard.",
    dashCaption: "Monthly sales, month-over-month trend, pending ingestions, upcoming due dates.",
    supCaptionLead: "Suppliers.",
    supCaption: "Unified catalog, location, IATA and category. No duplicates.",
    proveedores: [
      { flag: "🇲🇽", name: "Aeroméxico", iata: "AM", cat: "Airline" },
      { flag: "🇪🇸", name: "Iberia", iata: "IB", cat: "Airline" },
      { flag: "🇪🇸", name: "RIU Hotels", iata: "—", cat: "Hospitality" },
      { flag: "🇦🇷", name: "Despegar", iata: "—", cat: "OTA" },
      { flag: "🇵🇪", name: "Costamar", iata: "—", cat: "Wholesaler" },
    ],
  },
}[lang];
const dot = "w-[9px] h-[9px] rounded-full";
---

<section class="max-w-[1180px] mx-auto pt-24 px-6">
  <div class="reveal text-center max-w-[680px] mx-auto mb-12">
    <h2 class="text-[32px] sm:text-[40px] font-bold text-brand-700">{copy.heading}</h2>
    <p class="text-[19px] text-[#42485a] mt-3.5">{copy.sub}</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-7 items-start">
    <!-- Dashboard -->
    <div class="reveal">
      <div class="rounded-[18px] bg-white shadow-[0_20px_48px_-20px_rgba(14,31,58,0.28),0_0_0_1px_rgba(14,31,58,0.05)] overflow-hidden">
        <div class="h-9 flex items-center gap-1.5 px-3.5 bg-brand-700">
          <span class={`${dot} bg-accent-500`}></span><span class={`${dot} bg-brand-400`}></span><span class={`${dot} bg-[#2f9e6f]`}></span>
        </div>
        <div class="px-[22px] py-5">
          <div class="grid grid-cols-2 gap-3">
            <div class="bg-[#f6f4f0] rounded-[12px] px-4 py-3.5">
              <p class="text-[11px] font-semibold text-[#6b7280] tracking-[0.05em] uppercase">{copy.salesLabel}</p>
              <p class="font-display text-2xl font-bold text-brand-700 mt-[5px]">$1,284,500</p>
              <p class="text-xs font-semibold text-[#2f9e6f] mt-[3px]">{copy.salesDelta}</p>
            </div>
            <div class="bg-[#f6f4f0] rounded-[12px] px-4 py-3.5">
              <p class="text-[11px] font-semibold text-[#6b7280] tracking-[0.05em] uppercase">{copy.activeLabel}</p>
              <p class="font-display text-2xl font-bold text-brand-700 mt-[5px]">47</p>
              <p class="text-xs font-semibold text-accent-500 mt-[3px]">{copy.activeDelta}</p>
            </div>
          </div>
          <div class="mt-4 bg-[#f6f4f0] rounded-[12px] p-4">
            <p class="text-[11px] font-semibold text-[#6b7280] tracking-[0.05em] uppercase mb-3">{copy.trendLabel}</p>
            <div class="flex items-end gap-[9px] h-20">
              <div class="flex-1 h-[44%] bg-brand-200 rounded-t-[5px]"></div>
              <div class="flex-1 h-[58%] bg-brand-300 rounded-t-[5px]"></div>
              <div class="flex-1 h-[50%] bg-brand-200 rounded-t-[5px]"></div>
              <div class="flex-1 h-[72%] bg-brand-400 rounded-t-[5px]"></div>
              <div class="flex-1 h-[64%] bg-brand-300 rounded-t-[5px]"></div>
              <div class="flex-1 h-full bg-accent-500 rounded-t-[5px]"></div>
            </div>
          </div>
        </div>
      </div>
      <p class="text-[15px] text-[#42485a] mt-4"><strong class="text-brand-700 font-semibold">{copy.dashCaptionLead}</strong> {copy.dashCaption}</p>
    </div>

    <!-- Proveedores -->
    <div class="reveal">
      <div class="rounded-[18px] bg-white shadow-[0_20px_48px_-20px_rgba(14,31,58,0.28),0_0_0_1px_rgba(14,31,58,0.05)] overflow-hidden">
        <div class="h-9 flex items-center gap-1.5 px-3.5 bg-brand-700">
          <span class={`${dot} bg-accent-500`}></span><span class={`${dot} bg-brand-400`}></span><span class={`${dot} bg-[#2f9e6f]`}></span>
        </div>
        <div class="px-[22px] py-5">
          <h4 class="text-base font-bold text-brand-700 mb-3.5">{copy.suppliersTitle}</h4>
          {
            copy.proveedores.map((p) => (
              <div class="flex items-center gap-3.5 py-[11px] border-t border-[#f1f1ee]">
                <span class="text-[22px]">{p.flag}</span>
                <span class="flex-1 text-sm font-semibold text-ink">{p.name}</span>
                <span class="text-[11px] font-bold text-brand-400 bg-brand-50 px-2 py-[3px] rounded-md tracking-[0.04em]">{p.iata}</span>
                <span class="text-xs text-[#6b7280] w-20 text-right">{p.cat}</span>
              </div>
            ))
          }
        </div>
      </div>
      <p class="text-[15px] text-[#42485a] mt-4"><strong class="text-brand-700 font-semibold">{copy.supCaptionLead}</strong> {copy.supCaption}</p>
    </div>
  </div>
</section>
