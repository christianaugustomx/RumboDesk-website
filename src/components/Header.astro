---
import Logo from "./Logo.astro";
import { t, routes, languages, languageFlags, type Lang } from "../i18n/ui";
import { alternatePaths, type PageKey } from "../i18n/utils";

interface Props { lang: Lang; pageKey: PageKey; }
const { lang, pageKey } = Astro.props;
const r = routes[lang];
const otherLang: Lang = lang === "es" ? "en" : "es";
const otherPath = alternatePaths[pageKey][otherLang];

const links = [
  { href: r.product, label: t(lang, "nav.product") },
  { href: r.howItWorks, label: t(lang, "nav.howItWorks") },
  { href: r.pricing, label: t(lang, "nav.pricing") },
  { href: r.agencies, label: t(lang, "nav.agencies") },
  { href: r.operators, label: t(lang, "nav.operators") },
  { href: r.blog, label: t(lang, "nav.blog") },
];
---

<header
  id="site-header"
  class="sticky top-0 z-50 backdrop-blur-md border-b border-transparent transition-[background-color,border-color] duration-300"
>
  <nav class="max-w-[1180px] mx-auto px-6 h-[68px] flex items-center gap-8">
    <Logo />

    <div class="hidden md:flex items-center gap-7 flex-1">
      {
        links.map((l) => (
          <a href={l.href} class="text-[15px] font-medium text-brand-600 hover:text-brand-700 transition-colors">
            {l.label}
          </a>
        ))
      }
    </div>

    <div class="flex items-center gap-[18px] flex-none ml-auto md:ml-0">
      <a
        href={otherPath}
        class="flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-brand-200 text-sm font-semibold text-brand-500 hover:border-brand-300 hover:text-brand-700 hover:bg-brand-50 transition-colors"
        aria-label="Switch language"
      >
        <span aria-hidden="true">{languageFlags[otherLang]}</span>
        <span class="hidden sm:inline">{languages[otherLang]}</span>
      </a>
      <a href="https://rumbodesk.app" class="hidden sm:inline text-[15px] font-semibold text-brand-700">
        {t(lang, "nav.login")}
      </a>
      <a
        href="https://rumbodesk.app"
        class="inline-flex items-center px-[18px] py-[9px] bg-accent-500 text-white font-semibold text-[15px] rounded-[10px] shadow-[0_6px_16px_rgba(201,123,74,0.28)] hover:bg-accent-600 hover:-translate-y-0.5 transition-[background-color,transform] duration-200"
      >
        {t(lang, "nav.cta")}
      </a>
    </div>
  </nav>
</header>

<script>
  const header = document.getElementById("site-header");
  const onScroll = () => {
    if (!header) return;
    if (window.scrollY > 20) {
      header.style.backgroundColor = "rgba(250,248,245,0.85)";
      header.style.borderBottomColor = "rgba(14,31,58,0.08)";
    } else {
      header.style.backgroundColor = "rgba(250,248,245,0)";
      header.style.borderBottomColor = "transparent";
    }
  };
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });
</script>
