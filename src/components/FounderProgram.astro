---
import { type Lang } from "../i18n/ui";
interface Props { lang: Lang; }
const { lang } = Astro.props;

const copy = {
  es: {
    badge: "⭐ Programa fundador · Cupos limitados",
    heading: "Las primeras 10 agencias de LATAM construyen RumboDesk con nosotros.",
    body: "Plan Profesional gratis durante 3 meses a cambio de feedback constante. Te ayudamos a migrar tu operación y priorizamos features que tu equipo necesita.",
    cta: "Aplicar al programa",
    micro: "Sin tarjeta · respuesta en 24h",
  },
  en: {
    badge: "⭐ Founder program · Limited spots",
    heading: "The first 10 agencies in LATAM build RumboDesk with us.",
    body: "Professional plan free for 3 months in exchange for constant feedback. We help you migrate your operation and prioritize the features your team needs.",
    cta: "Apply to the program",
    micro: "No card · reply within 24h",
  },
}[lang];
---

<section class="max-w-[1180px] mx-auto pt-24 px-6">
  <div class="reveal relative overflow-hidden rounded-[24px] px-12 py-[60px] text-center bg-gradient-to-br from-brand-600 to-brand-700 shadow-[0_30px_60px_-20px_rgba(14,31,58,0.45)]">
    <div class="absolute -top-[60px] -right-10 w-[280px] h-[280px] rounded-full bg-[radial-gradient(circle,rgba(201,123,74,0.22),transparent_70%)]"></div>
    <div class="relative">
      <span class="inline-block px-4 py-[7px] bg-[rgba(201,123,74,0.20)] border border-[rgba(201,123,74,0.35)] rounded-full text-[13px] font-semibold text-accent-200 tracking-[0.02em]">
        {copy.badge}
      </span>
      <h2 class="text-[30px] sm:text-[38px] font-bold text-white mt-[22px] max-w-[760px] mx-auto leading-[1.12]">
        {copy.heading}
      </h2>
      <p class="text-lg leading-[1.6] text-brand-100 mt-[18px] max-w-[640px] mx-auto">
        {copy.body}
      </p>
      <div class="flex flex-col items-center gap-3 mt-[30px]">
        <a
          href="https://rumbodesk.app"
          class="inline-flex items-center px-7 py-3.5 bg-accent-500 text-white font-semibold text-base rounded-[11px] shadow-[0_12px_28px_rgba(201,123,74,0.4)] hover:bg-accent-400 hover:-translate-y-[3px] transition-[background-color,transform] duration-200"
        >
          {copy.cta}
        </a>
        <span class="text-sm text-[#9fb0cc]">{copy.micro}</span>
      </div>
    </div>
  </div>
</section>
