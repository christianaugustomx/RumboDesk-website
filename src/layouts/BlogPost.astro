---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { existsSync } from 'node:fs';
import { join } from 'node:path';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const d = post.data;
const lang = d.lang;
const isEn = lang === 'en';

const site = 'https://rumbodesk.com';
const blogBase = isEn ? `${site}/en/blog` : `${site}/blog`;
const canonical = d.canonicalURL ?? `${blogBase}/${post.id}`;
const pageTitle = d.seoTitle ?? d.title;

// Alterna hacia la traducción (si existe) para hreflang y el switcher del Header.
const translation = d.translationSlug
  ? (await getCollection('blog', ({ id, data }) => id === d.translationSlug && data.lang !== lang))[0]
  : undefined;
const translationHref = translation
  ? (isEn ? `${site}/blog/${translation.id}` : `${site}/en/blog/${translation.id}`)
  : undefined;
const esHref = isEn ? translationHref : canonical;

// La portada sólo se muestra si el archivo existe en /public; si aún no se
// sube, el hero no se renderiza y la imagen social cae a og-default.png.
// Al añadir el .webp a public/blog/ y reconstruir, la portada real aparece sola.
const heroExists =
  !!d.heroImage &&
  (d.heroImage.startsWith('http') || existsSync(join(process.cwd(), 'public', d.heroImage)));
const heroPath = heroExists ? (d.heroImage as string) : '/og-default.png';
const ogImage = heroPath.startsWith('http') ? heroPath : site + heroPath;

const pubISO = d.pubDate.toISOString();
const modISO = (d.updatedDate ?? d.pubDate).toISOString();
const dateLocale = isEn ? 'en-US' : 'es-MX';
const displayDate = d.pubDate.toLocaleDateString(dateLocale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const displayUpdated = d.updatedDate
  ? d.updatedDate.toLocaleDateString(dateLocale, { year: 'numeric', month: 'long', day: 'numeric' })
  : null;

const blogUrl = blogBase;
const homeUrl = isEn ? `${site}/en` : `${site}/`;
const i = isEn
  ? { htmlLang: 'en-US', home: 'Home', breadcrumbNav: 'Breadcrumb', updated: 'Updated on', ogLocale: 'en_US' }
  : { htmlLang: 'es-MX', home: 'Inicio', breadcrumbNav: 'Ruta de navegación', updated: 'Actualizado el', ogLocale: 'es_MX' };

// --- JSON-LD ---------------------------------------------------------------
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: d.title,
  description: d.description,
  inLanguage: i.htmlLang,
  datePublished: pubISO,
  dateModified: modISO,
  image: ogImage,
  author: { '@type': 'Organization', name: d.author, url: site },
  publisher: {
    '@type': 'Organization',
    name: 'RumboDesk',
    logo: {
      '@type': 'ImageObject',
      url: 'https://rumbodesk.com/logo-mark-white.webp',
    },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
};

const faqSchema =
  d.faq.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: d.faq.map((f) => ({
          '@type': 'Question',
          name: f.q,
          acceptedAnswer: { '@type': 'Answer', text: f.a },
        })),
      }
    : null;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: i.home, item: homeUrl },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: blogUrl },
    { '@type': 'ListItem', position: 3, name: d.title, item: canonical },
  ],
};
---

<!doctype html>
<html lang={i.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0E1F3A" />
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <title>{pageTitle}</title>
    <meta name="description" content={d.description} />
    <link rel="canonical" href={canonical} />

    <link rel="alternate" hreflang={isEn ? 'en' : 'es'} href={canonical} />
    {translationHref && <link rel="alternate" hreflang={isEn ? 'es' : 'en'} href={translationHref} />}
    <link rel="alternate" hreflang="x-default" href={esHref ?? canonical} />

    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="RumboDesk" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={d.description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={i.ogLocale} />
    {translationHref && <meta property="og:locale:alternate" content={isEn ? 'es_MX' : 'en_US'} />}
    <meta property="og:image" content={ogImage} />
    <meta property="article:published_time" content={pubISO} />
    <meta property="article:modified_time" content={modISO} />
    <meta property="article:section" content={d.category} />
    {d.tags.map((tag) => <meta property="article:tag" content={tag} />)}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={d.description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link href="https://api.fontshare.com/v2/css?f[]=general-sans@500,600,700&display=swap" rel="stylesheet" />

    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header lang={lang} pageKey="blog" altHref={translationHref} />
    <main class="flex-1">
      <article class="max-w-[720px] mx-auto px-4 sm:px-6 lg:px-8 py-14 sm:py-20">
        <nav aria-label={i.breadcrumbNav} class="text-sm text-brand-400 flex flex-wrap items-center gap-1.5">
          <a href={homeUrl} class="hover:text-brand-600 transition-colors">{i.home}</a>
          <span aria-hidden="true">›</span>
          <a href={blogUrl.replace(site, '')} class="hover:text-brand-600 transition-colors">Blog</a>
          <span aria-hidden="true">›</span>
          <span class="text-brand-600 font-medium">{d.title}</span>
        </nav>

        <header class="mt-8">
          <span class="inline-flex items-center rounded-full bg-accent-50 text-accent-700 text-xs font-semibold px-3 py-1 tracking-wide uppercase">
            {d.category}
          </span>
          <h1 class="mt-4 text-3xl sm:text-4xl lg:text-[2.6rem] font-extrabold text-brand-900 leading-[1.12]">
            {d.title}
          </h1>
          <div class="mt-4 flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-brand-400">
            <span>{d.author}</span>
            <span aria-hidden="true">·</span>
            <time datetime={pubISO}>{displayDate}</time>
            {displayUpdated && (
              <>
                <span aria-hidden="true">·</span>
                <span>{i.updated} {displayUpdated}</span>
              </>
            )}
          </div>
        </header>

        {heroExists && (
          <img
            src={d.heroImage}
            alt={d.heroImageAlt ?? d.title}
            class="mt-8 w-full rounded-2xl border border-brand-100 object-cover"
            loading="eager"
            width="720"
            height="405"
          />
        )}

        <div class="article mt-10">
          <slot />
        </div>
      </article>
    </main>
    <Footer lang={lang} />
  </body>
</html>
