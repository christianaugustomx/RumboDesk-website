---
import '../styles/global.css';
---

<!doctype html>
<html lang="es-MX">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0E1F3A" />
    <meta name="robots" content="noindex,follow" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <title>Página no encontrada — RumboDesk</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://api.fontshare.com/v2/css?f[]=general-sans@500,600,700&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen flex items-center justify-center px-6 text-center">
    <div class="max-w-md">
      <img src="/logo-mark-white.webp" alt="RumboDesk" width="56" height="56" class="w-14 h-14 rounded-[12px] mx-auto" />
      <p class="font-display font-bold text-[64px] leading-none text-brand-700 mt-8">404</p>
      <h1 class="font-display text-2xl font-bold text-brand-700 mt-2">Esta página se salió de rumbo.</h1>
      <p class="text-[#42485a] mt-3">
        La página que buscas no existe o cambió de lugar.
        <span class="block text-sm text-[#6b7280] mt-1">The page you're looking for doesn't exist.</span>
      </p>
      <div class="flex gap-3 justify-center mt-7 flex-wrap">
        <a
          href="/"
          class="inline-flex items-center px-[22px] py-3 bg-accent-500 text-white font-semibold rounded-[11px] shadow-[0_8px_20px_rgba(201,123,74,0.28)] hover:bg-accent-600 transition-colors"
        >
          Ir al inicio
        </a>
        <a
          href="/en"
          class="inline-flex items-center px-[22px] py-3 text-brand-700 font-semibold rounded-[11px] border border-brand-300 bg-white hover:bg-brand-50 transition-colors"
        >
          Go to homepage
        </a>
      </div>
    </div>
  </body>
</html>
