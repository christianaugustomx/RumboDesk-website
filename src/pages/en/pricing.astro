---
import BaseLayout from '../../layouts/BaseLayout.astro';
const lang = 'en' as const;
const title = 'Pricing — RumboDesk · Plans from $799 MXN/month';
const description = 'Three plans for operators and agencies in LATAM. Essential, Professional and Enterprise. Pricing in Mexican pesos.';

const plans = [
  { name: 'Essential', price: '$799', period: '/mo', audience: 'Independent operators and agents getting started',
    bullets: ['Up to 30 active bookings','Email ingest + paste','1 user','Unlimited supplier catalog','Email support'],
    cta: 'Start Essential', highlight: false },
  { name: 'Professional', price: '$1,599', period: '/mo', audience: 'Small agencies and growing operators',
    bullets: ['Up to 200 active bookings','Up to 5 users','PDF & Word with OCR','Visa & passport tracking','Financial reports (MoM, commissions)','Priority support'],
    cta: 'Start Professional', highlight: true },
  { name: 'Enterprise', price: '$9,999', period: '/mo', audience: 'Mid/large agencies with high volume',
    bullets: ['Unlimited bookings','Unlimited users','API + integrations','CFDI 4.0 invoicing','Assisted onboarding','Dedicated support'],
    cta: 'Talk to sales', highlight: false },
];
---
<BaseLayout lang={lang} pageKey="pricing" title={title} description={description}>
  <section class="py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-extrabold text-brand-900">Simple pricing. No surprises.</h1>
      <p class="mt-4 text-lg text-gray-700">All plans include AI ingest, human review, multi-language and original-file backup.</p>
      <p class="mt-2 text-sm text-gray-500">Prices in MXN. Tax not included. 14-day trial, no card.</p>
    </div>
  </section>
  <section class="pb-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-3 gap-6">
      {plans.map(p => (
        <div class={`p-8 rounded-2xl bg-white border ${p.highlight ? 'border-brand-500 ring-2 ring-brand-500/30 shadow-lg' : 'border-gray-200'}`}>
          {p.highlight && <div class="text-xs font-bold uppercase tracking-wide text-brand-600 mb-2">Most popular</div>}
          <h3 class="text-2xl font-bold text-brand-900">{p.name}</h3>
          <p class="mt-1 text-sm text-gray-600">{p.audience}</p>
          <div class="mt-6 flex items-baseline gap-1">
            <span class="text-4xl font-extrabold text-brand-900">{p.price}</span>
            <span class="text-gray-600">{p.period} MXN</span>
          </div>
          <ul class="mt-6 space-y-3 text-sm text-gray-700">
            {p.bullets.map(b => (<li class="flex gap-2"><span class="text-brand-500">✓</span>{b}</li>))}
          </ul>
          <a href="https://app.rumbodesk.app" class={`mt-8 block text-center ${p.highlight ? 'btn-primary' : 'btn-ghost'}`}>{p.cta}</a>
        </div>
      ))}
    </div>
  </section>
  <section class="pb-20 text-center text-sm text-gray-600">
    <p>Need something different? <a href="/en/contact" class="text-brand-600 font-semibold hover:underline">Let's talk</a>.</p>
  </section>
</BaseLayout>
