---
import BaseLayout from '../../layouts/BaseLayout.astro';
const lang = 'en' as const;
const title = 'Pricing — RumboDesk · Plans from $499 MXN/month';
const description = 'Two simple plans for operators and agencies in LATAM. Essential and Professional. Pricing in Mexican pesos.';

const plans = [
  { name: 'Essential', price: '$499', period: '/mo', annualPrice: '$4,990', annualEquivalent: '$416',
    priceUsd: '$29', annualPriceUsd: '$290', annualEquivalentUsd: '$24',
    audience: 'Independent operators and agents getting started',
    bullets: ['Up to 50 bookings per month','Up to 50 total ingestions per month','Up to 20 PDF/Word/image ingestions per month','Up to 20 chat messages per day','2 users','Unlimited supplier catalog'],
    cta: 'Start Essential', highlight: false },
  { name: 'Professional', price: '$999', period: '/mo', annualPrice: '$9,990', annualEquivalent: '$833',
    priceUsd: '$59', annualPriceUsd: '$590', annualEquivalentUsd: '$49',
    audience: 'Small agencies and growing operators',
    bullets: ['Unlimited bookings','Up to 200 PDF/Word/image ingestions','Up to 100 AI assistant messages per day','Up to 15 users','Unlimited supplier catalog','Visa tracking + financial reports','Dedicated number for WhatsApp ingest'],
    cta: 'Start Professional', highlight: true },
];
---
<BaseLayout lang={lang} pageKey="pricing" title={title} description={description}>
  <section class="py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-extrabold text-brand-900">Simple pricing. No surprises.</h1>
      <p class="mt-4 text-lg text-gray-700">All plans include AI ingest, human review, multi-language and original-file backup.</p>
      <p class="mt-2 text-sm text-gray-500">Prices in MXN or USD, depending on your market. Tax not included. 14-day trial, no card.</p>
      <div class="mt-4 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-gray-600">
        <span class="flex items-center gap-1.5"><span class="text-accent-500">✓</span>14 days free</span>
        <span class="flex items-center gap-1.5"><span class="text-accent-500">✓</span>No long-term contracts</span>
        <span class="flex items-center gap-1.5"><span class="text-accent-500">✓</span>Cancel anytime</span>
      </div>

      <div class="mt-8 inline-flex items-center gap-1 p-1 rounded-full bg-white border border-gray-200" id="billing-toggle">
        <button type="button" class="billing-toggle-btn px-4 py-2 rounded-full text-sm font-semibold transition-colors" data-billing="monthly">Monthly</button>
        <button type="button" class="billing-toggle-btn flex items-center gap-2 px-4 py-2 rounded-full text-sm font-semibold transition-colors" data-billing="annual">
          Annual
          <span class="text-[11px] font-bold text-white bg-accent-500 px-2 py-0.5 rounded-full whitespace-nowrap">2 months free</span>
        </button>
      </div>

      <div class="mt-3 inline-flex items-center gap-1 p-1 rounded-full bg-white border border-gray-200" id="currency-toggle">
        <button type="button" class="currency-toggle-btn px-4 py-2 rounded-full text-sm font-semibold transition-colors text-brand-600" data-currency="mxn">MXN</button>
        <button type="button" class="currency-toggle-btn px-4 py-2 rounded-full text-sm font-semibold transition-colors bg-accent-500 text-white" data-currency="usd">USD</button>
      </div>
    </div>
  </section>
  <section class="pb-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-2 gap-6">
      {plans.map(p => (
        <div class={`p-8 rounded-2xl bg-white border ${p.highlight ? 'border-accent-500 ring-2 ring-accent-500/30 shadow-lg' : 'border-gray-200'}`}>
          {p.highlight && <div class="text-xs font-bold uppercase tracking-wide text-brand-600 mb-2">Most popular</div>}
          <h3 class="text-2xl font-bold text-brand-900">{p.name}</h3>
          <p class="mt-1 text-sm text-gray-600">{p.audience}</p>
          <div class="mt-6" data-price-monthly>
            <div class="hidden" data-currency-block="mxn">
              <div class="flex items-baseline gap-1">
                <span class="text-4xl font-extrabold text-brand-900">{p.price}</span>
                <span class="text-gray-600">{p.period} MXN</span>
              </div>
            </div>
            <div data-currency-block="usd">
              <div class="flex items-baseline gap-1">
                <span class="text-4xl font-extrabold text-brand-900">{p.priceUsd}</span>
                <span class="text-gray-600">{p.period} USD</span>
              </div>
            </div>
          </div>
          <div class="mt-6 hidden" data-price-annual>
            <div class="hidden" data-currency-block="mxn">
              <div class="flex items-baseline gap-1">
                <span class="text-4xl font-extrabold text-brand-900">{p.annualPrice}</span>
                <span class="text-gray-600">/yr MXN</span>
              </div>
              <p class="mt-1 text-sm text-gray-500">≈ {p.annualEquivalent}/mo · 2 months free</p>
            </div>
            <div data-currency-block="usd">
              <div class="flex items-baseline gap-1">
                <span class="text-4xl font-extrabold text-brand-900">{p.annualPriceUsd}</span>
                <span class="text-gray-600">/yr USD</span>
              </div>
              <p class="mt-1 text-sm text-gray-500">≈ {p.annualEquivalentUsd}/mo · 2 months free</p>
            </div>
          </div>
          <ul class="mt-6 space-y-3 text-sm text-gray-700">
            {p.bullets.map(b => (<li class="flex gap-2"><span class="text-accent-500">✓</span>{b}</li>))}
          </ul>
          <a href="https://rumbodesk.app" class={`mt-8 block text-center ${p.highlight ? 'btn-primary' : 'btn-ghost'}`}>{p.cta}</a>
        </div>
      ))}
    </div>
  </section>
  <section class="pb-14">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-gray-200 bg-white p-8">
        <h3 class="text-xl font-bold text-brand-900">Billing and tax compliance</h3>
        <p class="mt-3 text-gray-700 leading-relaxed">
          All of our software services are invoiced as a 100% tax-deductible business expense in
          Mexico through our incorporated legal entity, Rumbo Tech Labs, S.A.S. de C.V.
          (Tax ID / RFC: RTL260323S44). We issue Mexican digital tax receipts (CFDI 4.0) under the
          general-expenses invoice-use code (G03), applicable to the acquisition of technology
          assets and software services. This applies to any plan, regardless of the size of your
          operation.
        </p>
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-gray-200 bg-paper p-8 text-center">
        <h3 class="text-xl font-bold text-brand-900">Large agency or specific needs?</h3>
        <p class="mt-2 text-gray-700">If you need more users, custom integrations, or a different agreement, we'll build it with you.</p>
        <a href="/en/contact" class="mt-5 inline-flex btn-ghost">Talk to us</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  function setBilling(mode: string) {
    document.querySelectorAll('[data-price-monthly]').forEach((el) => el.classList.toggle('hidden', mode !== 'monthly'));
    document.querySelectorAll('[data-price-annual]').forEach((el) => el.classList.toggle('hidden', mode !== 'annual'));
    document.querySelectorAll('.billing-toggle-btn').forEach((btn) => {
      const active = (btn as HTMLElement).dataset.billing === mode;
      btn.classList.toggle('bg-accent-500', active);
      btn.classList.toggle('text-white', active);
      btn.classList.toggle('text-brand-600', !active);
    });
  }
  document.querySelectorAll('.billing-toggle-btn').forEach((btn) => {
    btn.addEventListener('click', () => setBilling((btn as HTMLElement).dataset.billing || 'monthly'));
  });
  setBilling('monthly');

  // Independent of the billing toggle -- lives inside BOTH billing blocks
  // (monthly and annual) at once, so it's just show/hide by
  // data-currency-block regardless of which billing block is active.
  function setCurrency(cur: string) {
    document.querySelectorAll('[data-currency-block]').forEach((el) => {
      el.classList.toggle('hidden', (el as HTMLElement).dataset.currencyBlock !== cur);
    });
    document.querySelectorAll('.currency-toggle-btn').forEach((btn) => {
      const active = (btn as HTMLElement).dataset.currency === cur;
      btn.classList.toggle('bg-accent-500', active);
      btn.classList.toggle('text-white', active);
      btn.classList.toggle('text-brand-600', !active);
    });
  }
  document.querySelectorAll('.currency-toggle-btn').forEach((btn) => {
    btn.addEventListener('click', () => setCurrency((btn as HTMLElement).dataset.currency || 'usd'));
  });
  setCurrency('usd');
</script>
