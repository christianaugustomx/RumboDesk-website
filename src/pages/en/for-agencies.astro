---
import BaseLayout from '../../layouts/BaseLayout.astro';
const lang = 'en' as const;
const title = 'RumboDesk for travel agencies — CRM + bookings in one place';
const description = 'Multiple agents, hundreds of bookings, one source of truth. CRM, commissions, deadlines and reports for your travel agency.';
---
<BaseLayout lang={lang} pageKey="agencies" title={title} description={description}>
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="inline-block px-3 py-1 rounded-full bg-brand-100 text-brand-700 text-xs font-semibold uppercase">For agencies</span>
      <h1 class="mt-4 text-4xl sm:text-5xl font-extrabold text-brand-900">Your agency, organized. Your agents, productive.</h1>
      <p class="mt-4 text-lg text-gray-700">Every agent forwards their emails to one inbox. RumboDesk routes, structures and assigns. You see everything from a single live dashboard.</p>
    </div>
  </section>
  <section class="py-12 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-2 gap-8">
      <div class="p-6 rounded-2xl bg-paper border border-gray-100"><h3 class="font-bold text-brand-900">Client CRM</h3><p class="mt-2 text-gray-700 text-sm">Every booking linked to a client. Full history, preferences, passports, visas and birthdays.</p></div>
      <div class="p-6 rounded-2xl bg-paper border border-gray-100"><h3 class="font-bold text-brand-900">Commissions & reports</h3><p class="mt-2 text-gray-700 text-sm">Financial KPIs with MoM trends. Commission per agent, supplier, destination.</p></div>
      <div class="p-6 rounded-2xl bg-paper border border-gray-100"><h3 class="font-bold text-brand-900">Multi-user with roles</h3><p class="mt-2 text-gray-700 text-sm">Owner, manager, agent. Everyone sees what they should. Managers see everything.</p></div>
      <div class="p-6 rounded-2xl bg-paper border border-gray-100"><h3 class="font-bold text-brand-900">Deadlines & deposits</h3><p class="mt-2 text-gray-700 text-sm">Visible due dates, no more penalty fees for forgotten payments.</p></div>
    </div>
  </section>
  <section class="py-16 text-center"><a href="https://rumbodesk.app" class="btn-primary">Try with your agency</a></section>
</BaseLayout>
