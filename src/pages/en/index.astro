---
import BaseLayout from '../../layouts/BaseLayout.astro';
const lang = 'en' as const;
const title = 'RumboDesk — The AI copilot for travel agencies in LATAM';
const description = 'Stop copying and pasting. Forward emails, PDFs or WhatsApp notes; RumboDesk turns them into structured bookings in seconds. Human review before confirming.';
---
<BaseLayout lang={lang} pageKey="home" title={title} description={description}>

  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-50 via-paper to-white"></div>
    <div class="pointer-events-none absolute -top-32 left-1/2 -translate-x-1/2 w-[760px] h-[760px] rounded-full bg-brand-200/35 blur-3xl"></div>
    <div class="pointer-events-none absolute top-40 right-[-120px] w-[420px] h-[420px] rounded-full bg-brand-300/25 blur-3xl"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-24 text-center">
      <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-100 text-brand-700 text-xs font-semibold uppercase tracking-wide ring-1 ring-brand-200">
        <span class="w-1.5 h-1.5 rounded-full bg-brand-500 animate-pulse"></span>
        Built in Mexico · For LATAM
      </span>
      <h1 class="mt-6 text-4xl sm:text-5xl lg:text-6xl font-extrabold text-brand-900 tracking-tight max-w-4xl mx-auto">
        The <span class="text-brand-500">AI</span> copilot for travel agencies in LATAM.
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-gray-700 max-w-2xl mx-auto">
        Stop copying and pasting. Forward the email, upload the PDF or paste the WhatsApp — RumboDesk turns it into a structured booking in seconds. You review and confirm.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
        <a href="https://rumbodesk.app" class="btn-primary">Try free</a>
        <a href="/en/product" class="btn-ghost">See how it works</a>
      </div>
      <p class="mt-4 text-sm text-gray-500">No credit card · 14-day trial · Spanish & English</p>

      <div class="mt-16 max-w-5xl mx-auto reveal">
        <div class="rounded-2xl shadow-2xl ring-1 ring-gray-200 overflow-hidden bg-white hover-zoom">
          <img src="/screenshot-reservas.png" alt="Bookings view in RumboDesk — list of bookings with status, client, dates and amounts" width="1850" height="870" class="w-full h-auto" loading="eager" fetchpriority="high" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 reveal">
      <div class="text-center max-w-2xl mx-auto">
        <h2 class="text-3xl sm:text-4xl font-bold text-brand-900">Without RumboDesk vs. with RumboDesk</h2>
        <p class="mt-3 text-gray-700">Same work. Ten times less effort.</p>
      </div>

      <div class="mt-12 grid md:grid-cols-2 gap-6">
        <div class="p-8 rounded-2xl bg-red-50/40 border border-red-100">
          <div class="flex items-center gap-2">
            <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-red-100 text-red-700">⚠</span>
            <h3 class="text-xl font-bold text-red-900">Today's chaos</h3>
          </div>
          <ul class="mt-6 space-y-3 text-sm text-gray-700">
            <li class="flex gap-3"><span class="text-red-400">✕</span><span><b>Confirmation emails</b> forwarded to 4 different people.</span></li>
            <li class="flex gap-3"><span class="text-red-400">✕</span><span><b>Airline PDFs</b> nobody opens until the client complains.</span></li>
            <li class="flex gap-3"><span class="text-red-400">✕</span><span><b>WhatsApp from the supplier</b> buried in a group with 38 prior messages.</span></li>
            <li class="flex gap-3"><span class="text-red-400">✕</span><span><b>Master spreadsheet</b> with three versions, none up-to-date.</span></li>
            <li class="flex gap-3"><span class="text-red-400">✕</span><span><b>Typos</b>: a wrong date, a duplicate supplier.</span></li>
            <li class="flex gap-3"><span class="text-red-400">✕</span><span><b>Forgotten deadlines</b>: the Friday deposit nobody chased.</span></li>
          </ul>
        </div>

        <div class="p-8 rounded-2xl bg-brand-50 border border-brand-100 relative overflow-hidden">
          <div class="pointer-events-none absolute -top-20 -right-20 w-72 h-72 rounded-full bg-brand-200/40 blur-3xl"></div>
          <div class="relative">
            <div class="flex items-center gap-2">
              <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-brand-100 text-brand-700">✓</span>
              <h3 class="text-xl font-bold text-brand-900">With RumboDesk</h3>
            </div>
            <ul class="mt-6 space-y-3 text-sm text-gray-800">
              <li class="flex gap-3"><span class="text-brand-500 font-bold">✓</span><span><b>One inbox</b> for your whole org: <code class="text-brand-700">yourorg@rumbodesk.app</code>.</span></li>
              <li class="flex gap-3"><span class="text-brand-500 font-bold">✓</span><span><b>AI that reads PDFs</b>, Word, Excel and images and structures them.</span></li>
              <li class="flex gap-3"><span class="text-brand-500 font-bold">✓</span><span><b>Paste WhatsApp</b> directly and it becomes a booking.</span></li>
              <li class="flex gap-3"><span class="text-brand-500 font-bold">✓</span><span><b>One place</b> for the truth: dashboard, bookings, suppliers.</span></li>
              <li class="flex gap-3"><span class="text-brand-500 font-bold">✓</span><span><b>Human review always</b>: AI proposes, you confirm.</span></li>
              <li class="flex gap-3"><span class="text-brand-500 font-bold">✓</span><span><b>Deadlines visible</b>: payments, deposits and due dates without surprises.</span></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 reveal">
      <div class="text-center max-w-2xl mx-auto">
        <h2 class="text-3xl font-bold text-brand-900">Three steps. One spotless booking.</h2>
        <p class="mt-3 text-gray-700">From email, WhatsApp, PDF, Word, Excel or plain pasted text.</p>
      </div>
      <div class="mt-12 grid md:grid-cols-3 gap-6">
        <div class="p-6 rounded-2xl bg-white border border-gray-100 shadow-sm hover-lift">
          <div class="w-10 h-10 rounded-lg bg-brand-100 text-brand-700 font-bold flex items-center justify-center">1</div>
          <h3 class="mt-4 text-xl font-bold text-brand-900">Ingest</h3>
          <p class="mt-2 text-gray-700">Forward the email to your RumboDesk inbox, upload the PDF, or paste the text. Attachments included.</p>
        </div>
        <div class="p-6 rounded-2xl bg-white border border-gray-100 shadow-sm hover-lift">
          <div class="w-10 h-10 rounded-lg bg-brand-100 text-brand-700 font-bold flex items-center justify-center">2</div>
          <h3 class="mt-4 text-xl font-bold text-brand-900">Structure</h3>
          <p class="mt-2 text-gray-700">Our AI detects client, supplier, dates, costs and assembles the booking. You review in seconds.</p>
        </div>
        <div class="p-6 rounded-2xl bg-white border border-gray-100 shadow-sm hover-lift">
          <div class="w-10 h-10 rounded-lg bg-brand-100 text-brand-700 font-bold flex items-center justify-center">3</div>
          <h3 class="mt-4 text-xl font-bold text-brand-900">Confirm</h3>
          <p class="mt-2 text-gray-700">You approve, and it's saved with deadlines, commission, a unique supplier and the original file.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-2 gap-6 reveal">
      <a href="/en/for-agencies" class="group p-8 rounded-2xl border border-gray-100 bg-paper hover:bg-brand-50 hover-lift">
        <h3 class="text-2xl font-bold text-brand-900">For agencies</h3>
        <p class="mt-2 text-gray-700">Multiple agents, dozens of bookings a day, one source of truth. CRM, commissions, deadlines.</p>
        <span class="mt-4 inline-block text-brand-600 font-semibold group-hover:underline">See more →</span>
      </a>
      <a href="/en/for-operators" class="group p-8 rounded-2xl border border-gray-100 bg-paper hover:bg-brand-50 hover-lift">
        <h3 class="text-2xl font-bold text-brand-900">For operators</h3>
        <p class="mt-2 text-gray-700">Your suppliers, your packages, your rates. Passports, visas and deadlines under control.</p>
        <span class="mt-4 inline-block text-brand-600 font-semibold group-hover:underline">See more →</span>
      </a>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 reveal">
      <div class="relative overflow-hidden rounded-3xl bg-brand-900 text-white p-10 sm:p-14">
        <div class="pointer-events-none absolute -top-32 -left-20 w-[420px] h-[420px] rounded-full bg-brand-500/30 blur-3xl"></div>
        <div class="pointer-events-none absolute -bottom-32 -right-20 w-[420px] h-[420px] rounded-full bg-brand-300/20 blur-3xl"></div>
        <div class="relative grid md:grid-cols-3 gap-8 items-center">
          <div class="md:col-span-2">
            <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-500/20 text-brand-200 text-xs font-semibold uppercase tracking-wide ring-1 ring-brand-400/40">
              Founder program · Limited seats
            </span>
            <h2 class="mt-4 text-3xl sm:text-4xl font-extrabold">The first 10 LATAM agencies build RumboDesk with us.</h2>
            <p class="mt-4 text-brand-100">Professional plan free for one year in exchange for ongoing feedback. We help you migrate your operation and prioritize features your team needs.</p>
          </div>
          <div class="flex flex-col gap-3 md:items-end">
            <a href="https://rumbodesk.app" class="btn-primary !bg-white !text-brand-700 hover:!bg-brand-50 w-full md:w-auto justify-center">Apply now</a>
            <span class="text-xs text-brand-200">No card · reply in 24h</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto">
        <h2 class="text-3xl font-bold text-brand-900">This is what RumboDesk looks like</h2>
        <p class="mt-3 text-gray-700">Three views, one operation under control.</p>
      </div>

      <div class="mt-12 space-y-12">
        <div class="reveal">
          <div class="rounded-2xl shadow-xl ring-1 ring-gray-200 overflow-hidden bg-white hover-zoom">
            <img src="/screenshot-dashboard.png" alt="RumboDesk dashboard with financial KPIs and seasonal insights" width="1850" height="870" class="w-full h-auto" loading="lazy" />
          </div>
          <p class="mt-4 text-sm text-gray-600 text-center">
            <strong class="text-brand-900">Dashboard.</strong> Monthly sales, month-over-month trend, pending ingestions, upcoming deadlines.
          </p>
        </div>

        <div class="reveal">
          <div class="rounded-2xl shadow-xl ring-1 ring-gray-200 overflow-hidden bg-white hover-zoom">
            <img src="/screenshot-proveedores.png" alt="Supplier catalog in RumboDesk with country flag, IATA and category" width="1850" height="870" class="w-full h-auto" loading="lazy" />
          </div>
          <p class="mt-4 text-sm text-gray-600 text-center">
            <strong class="text-brand-900">Suppliers.</strong> Unified catalog, location, IATA and category. No duplicates.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 reveal">
      <div class="text-center">
        <h2 class="text-3xl sm:text-4xl font-bold text-brand-900">Frequently asked</h2>
        <p class="mt-3 text-gray-700">The questions agencies and operators ask us before getting started.</p>
      </div>

      <div class="mt-12 space-y-3">
        <details class="group rounded-2xl border border-gray-200 bg-paper open:bg-white open:shadow-sm">
          <summary class="cursor-pointer list-none px-6 py-5 flex items-center justify-between text-base font-semibold text-brand-900">
            Is it safe to share my clients' data?
            <span class="ml-4 text-brand-500 transition-transform group-open:rotate-180">▾</span>
          </summary>
          <div class="px-6 pb-6 text-gray-700 text-sm leading-relaxed">
            Yes. Encryption in transit (TLS) and at rest, per-organization isolation (multi-tenant) on Supabase, and Anthropic's AI does not use your data to train its models. Our LFPDPPP-compliant Privacy Notice covers the full flow.
          </div>
        </details>

        <details class="group rounded-2xl border border-gray-200 bg-paper open:bg-white open:shadow-sm">
          <summary class="cursor-pointer list-none px-6 py-5 flex items-center justify-between text-base font-semibold text-brand-900">
            Which formats can I forward or upload?
            <span class="ml-4 text-brand-500 transition-transform group-open:rotate-180">▾</span>
          </summary>
          <div class="px-6 pb-6 text-gray-700 text-sm leading-relaxed">
            Forwarded emails, PDFs (Aeromexico, Despegar, Booking, Expedia, etc.), Word, Excel, WhatsApp paste, screenshots and images. Each org has its own inbox <code class="bg-brand-50 px-1.5 py-0.5 rounded text-brand-700">yourorg@rumbodesk.app</code>.
          </div>
        </details>

        <details class="group rounded-2xl border border-gray-200 bg-paper open:bg-white open:shadow-sm">
          <summary class="cursor-pointer list-none px-6 py-5 flex items-center justify-between text-base font-semibold text-brand-900">
            Do I need a credit card for the trial?
            <span class="ml-4 text-brand-500 transition-transform group-open:rotate-180">▾</span>
          </summary>
          <div class="px-6 pb-6 text-gray-700 text-sm leading-relaxed">
            No. The 14-day trial doesn't ask for a card. When it ends you can subscribe to Essential, Professional or Enterprise, or stay on a limited mode.
          </div>
        </details>

        <details class="group rounded-2xl border border-gray-200 bg-paper open:bg-white open:shadow-sm">
          <summary class="cursor-pointer list-none px-6 py-5 flex items-center justify-between text-base font-semibold text-brand-900">
            Can the AI be wrong?
            <span class="ml-4 text-brand-500 transition-transform group-open:rotate-180">▾</span>
          </summary>
          <div class="px-6 pb-6 text-gray-700 text-sm leading-relaxed">
            Yes — that's why <strong>nothing reaches your bookings without your OK</strong>. The AI proposes a structure with the original excerpt as evidence; you adjust and approve. It's assistance, not a replacement.
          </div>
        </details>

        <details class="group rounded-2xl border border-gray-200 bg-paper open:bg-white open:shadow-sm">
          <summary class="cursor-pointer list-none px-6 py-5 flex items-center justify-between text-base font-semibold text-brand-900">
            Can I cancel anytime?
            <span class="ml-4 text-brand-500 transition-transform group-open:rotate-180">▾</span>
          </summary>
          <div class="px-6 pb-6 text-gray-700 text-sm leading-relaxed">
            Yes, no penalty. If you cancel, you can export your data for 30 days. After that it is deleted per our Privacy Notice.
          </div>
        </details>

        <details class="group rounded-2xl border border-gray-200 bg-paper open:bg-white open:shadow-sm">
          <summary class="cursor-pointer list-none px-6 py-5 flex items-center justify-between text-base font-semibold text-brand-900">
            Do you support Mexican CFDI 4.0 invoicing?
            <span class="ml-4 text-brand-500 transition-transform group-open:rotate-180">▾</span>
          </summary>
          <div class="px-6 pb-6 text-gray-700 text-sm leading-relaxed">
            Yes on the Enterprise plan, and on the roadmap for Professional. Meanwhile you get a PDF invoice for the plan you subscribe to.
          </div>
        </details>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 reveal">
      <div class="rounded-3xl bg-brand-600 text-white p-10 sm:p-14 text-center">
        <h2 class="text-3xl sm:text-4xl font-extrabold">Get your first booking ingested in 5 minutes.</h2>
        <p class="mt-3 text-brand-100">Create your account, forward a confirmation email, watch it structure itself.</p>
        <a href="https://rumbodesk.app" class="mt-6 inline-flex btn-primary !bg-white !text-brand-700 hover:!bg-brand-50">Try RumboDesk free</a>
      </div>
    </div>
  </section>

</BaseLayout>
