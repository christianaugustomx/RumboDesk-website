---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import Comparison from "../../components/Comparison.astro";
import Steps from "../../components/Steps.astro";
import Segments from "../../components/Segments.astro";
import FounderProgram from "../../components/FounderProgram.astro";
import Showcase from "../../components/Showcase.astro";
import Faq from "../../components/Faq.astro";
import FinalCta from "../../components/FinalCta.astro";

const lang = "en" as const;
const title = "RumboDesk — The AI copilot for travel agencies in LATAM";
const description = "Stop copying and pasting. Forward emails, PDFs and WhatsApp notes; RumboDesk structures them into bookings in seconds. Human review before confirming.";
---

<BaseLayout lang={lang} pageKey="home" title={title} description={description}>
  <Hero lang={lang} />
  <Comparison lang={lang} />
  <Steps lang={lang} />
  <Segments lang={lang} />
  <FounderProgram lang={lang} />
  <Showcase lang={lang} />
  <Faq lang={lang} />
  <FinalCta lang={lang} />
</BaseLayout>
