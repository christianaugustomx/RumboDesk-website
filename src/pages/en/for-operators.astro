---
import BaseLayout from '../../layouts/BaseLayout.astro';
const lang = 'en' as const;
const title = 'RumboDesk for tour operators — suppliers & packages under control';
const description = 'LATAM supplier catalog, AI confirmation ingest, passports and visas. The operational tool for tour operators.';
---
<BaseLayout lang={lang} pageKey="operators" title={title} description={description}>
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="inline-block px-3 py-1 rounded-full bg-brand-100 text-brand-700 text-xs font-semibold uppercase">For operators</span>
      <h1 class="mt-4 text-4xl sm:text-5xl font-extrabold text-brand-900">Your packages, your suppliers, your control.</h1>
      <p class="mt-4 text-lg text-gray-700">Hotels, transport, guides, restaurants, flights. RumboDesk recognizes, unifies and packages them — duplicate-free, fully auditable.</p>
    </div>
  </section>
  <section class="py-12 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-2 gap-8">
      <div class="p-6 rounded-2xl bg-paper border border-gray-100"><h3 class="font-bold text-brand-900">LATAM-seeded catalog</h3><p class="mt-2 text-gray-700 text-sm">Start with a LATAM-focused supplier seed. What's missing gets added once and stays.</p></div>
      <div class="p-6 rounded-2xl bg-paper border border-gray-100"><h3 class="font-bold text-brand-900">Per-booking items</h3><p class="mt-2 text-gray-700 text-sm">Hotel + transport + guide + restaurant + activity + flight. Day by day. Cost and price separated.</p></div>
      <div class="p-6 rounded-2xl bg-paper border border-gray-100"><h3 class="font-bold text-brand-900">Passports & visas</h3><p class="mt-2 text-gray-700 text-sm">Passport scanning, expiration alerts, visa tracking per destination.</p></div>
      <div class="p-6 rounded-2xl bg-paper border border-gray-100"><h3 class="font-bold text-brand-900">Flights with IATA & country</h3><p class="mt-2 text-gray-700 text-sm">Origin and destination with IATA code and country flag. Bookings with context, not just text.</p></div>
    </div>
  </section>
  <section class="py-16 text-center"><a href="https://app.rumbodesk.app" class="btn-primary">Try for my operation</a></section>
</BaseLayout>
