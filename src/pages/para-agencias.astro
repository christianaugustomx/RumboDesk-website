---
import BaseLayout from '../layouts/BaseLayout.astro';
const lang = 'es' as const;
const title = 'RumboDesk para agencias de viajes — CRM + reservas en un solo lugar';
const description = 'Múltiples agentes, cientos de reservas, una sola fuente de verdad. CRM, comisiones, deadlines y reportes para tu agencia de viajes.';
---
<BaseLayout lang={lang} pageKey="agencies" title={title} description={description}>
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="inline-block px-3 py-1 rounded-full bg-brand-100 text-brand-700 text-xs font-semibold uppercase">Para agencias</span>
      <h1 class="mt-4 text-4xl sm:text-5xl font-extrabold text-brand-900">Tu agencia, ordenada. Tus agentes, productivos.</h1>
      <p class="mt-4 text-lg text-gray-700">Cada agente reenvía sus correos a un mismo buzón. RumboDesk reparte, estructura y asigna. Tú ves todo desde un dashboard único, en vivo.</p>
    </div>
  </section>

  <section class="py-12 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-2 gap-8">
      <div class="p-6 rounded-2xl bg-paper border border-gray-100">
        <h3 class="font-bold text-brand-900">CRM de clientes</h3>
        <p class="mt-2 text-gray-700 text-sm">Cada reserva queda vinculada al cliente. Historial completo, preferencias, pasaportes, visas y cumpleaños.</p>
      </div>
      <div class="p-6 rounded-2xl bg-paper border border-gray-100">
        <h3 class="font-bold text-brand-900">Comisiones y reportes</h3>
        <p class="mt-2 text-gray-700 text-sm">KPIs financieros con tendencia mes a mes. Comisión por agente, por proveedor, por destino.</p>
      </div>
      <div class="p-6 rounded-2xl bg-paper border border-gray-100">
        <h3 class="font-bold text-brand-900">Multi-usuario con roles</h3>
        <p class="mt-2 text-gray-700 text-sm">Owner, manager, agente. Cada quien ve lo suyo. Los gerentes ven todo.</p>
      </div>
      <div class="p-6 rounded-2xl bg-paper border border-gray-100">
        <h3 class="font-bold text-brand-900">Deadlines y depósitos</h3>
        <p class="mt-2 text-gray-700 text-sm">Vencimientos a la vista, sin más penalizaciones por olvidos.</p>
      </div>
    </div>
  </section>

  <section class="py-16 text-center">
    <a href="https://app.rumbodesk.app" class="btn-primary">Probar con tu agencia</a>
  </section>
</BaseLayout>
