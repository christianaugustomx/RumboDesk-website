---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const lang = 'es' as const;
const title = 'Blog — RumboDesk · Operación, IA y turismo en LATAM';
const description = 'Ideas, casos reales y guías prácticas para operadores y agencias de viaje en LATAM.';

const posts = (await getCollection('blog', ({ data }) => data.draft === false && data.lang === 'es')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const fmtDate = (date: Date) =>
  date.toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout lang={lang} pageKey="blog" title={title} description={description}>
  <section class="py-16 sm:py-20">
    <div class="max-w-[1180px] mx-auto px-6">
      <header class="max-w-2xl">
        <h1 class="text-4xl sm:text-5xl font-extrabold text-brand-900 leading-[1.1]">Blog</h1>
        <p class="mt-4 text-lg text-brand-500">
          Guías prácticas, casos reales y plantillas para operadores y agencias de viaje en LATAM.
        </p>
      </header>

      {
        posts.length === 0 ? (
          <p class="mt-12 text-brand-400">
            Pronto: guías, casos de uso y plantillas.{' '}
            <a href="/contacto" class="text-accent-600 font-semibold">¿Tienes un tema en mente? Escríbenos</a>.
          </p>
        ) : (
          <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {posts.map((post) => (
              <a
                href={`/blog/${post.id}`}
                class="reveal hover-lift group flex flex-col rounded-2xl border border-brand-100 bg-white p-6 shadow-[0_1px_2px_rgba(14,31,58,0.04)] hover:shadow-[0_12px_32px_rgba(14,31,58,0.10)] hover:border-brand-200"
              >
                <span class="inline-flex w-fit items-center rounded-full bg-accent-50 text-accent-700 text-xs font-semibold px-3 py-1 tracking-wide uppercase">
                  {post.data.category}
                </span>
                <h2 class="mt-4 text-xl font-bold text-brand-900 leading-snug group-hover:text-brand-700 transition-colors">
                  {post.data.title}
                </h2>
                <p class="mt-3 text-[15px] text-brand-500 leading-relaxed flex-1">
                  {post.data.description}
                </p>
                <div class="mt-5 flex items-center justify-between text-sm">
                  <time datetime={post.data.pubDate.toISOString()} class="text-brand-400">
                    {fmtDate(post.data.pubDate)}
                  </time>
                  <span class="font-semibold text-accent-600 group-hover:translate-x-0.5 transition-transform">
                    Leer →
                  </span>
                </div>
              </a>
            ))}
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
