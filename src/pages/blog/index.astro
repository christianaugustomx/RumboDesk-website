---
import BaseLayout from '../../layouts/BaseLayout.astro';
const lang = 'es' as const;
const title = 'Blog — RumboDesk · Operación, IA y turismo en LATAM';
const description = 'Ideas, casos reales y guías prácticas para operadores y agencias de viaje en LATAM.';
---
<BaseLayout lang={lang} pageKey="blog" title={title} description={description}>
  <section class="py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl sm:text-5xl font-extrabold text-brand-900">Blog</h1>
      <p class="mt-4 text-lg text-gray-700">Pronto: guías, casos de uso y plantillas para operadores y agencias en LATAM.</p>
      <p class="mt-2 text-sm text-gray-500">¿Tienes un tema en mente? <a href="/contacto" class="text-brand-600 font-semibold">Escríbenos</a>.</p>
    </div>
  </section>
</BaseLayout>
