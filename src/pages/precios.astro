---
import BaseLayout from '../layouts/BaseLayout.astro';
const lang = 'es' as const;
const title = 'Precios — RumboDesk · Planes desde $499 MXN al mes';
const description = 'Dos planes simples para operadores y agencias en LATAM. Esencial y Profesional. Precios en pesos mexicanos.';

const plans = [
  {
    name: 'Esencial',
    price: '$499',
    period: '/mes',
    annualPrice: '$4,990',
    annualEquivalent: '$416',
    audience: 'Operadores y agentes independientes que arrancan',
    bullets: [
      'Hasta 50 reservas al mes',
      'Ingest por email + pegado de texto',
      '2 usuarios',
      'Catálogo de proveedores ilimitado',
      'Soporte por email',
    ],
    cta: 'Empezar Esencial',
    highlight: false,
  },
  {
    name: 'Profesional',
    price: '$999',
    period: '/mes',
    annualPrice: '$9,990',
    annualEquivalent: '$833',
    audience: 'Agencias pequeñas y operadores en crecimiento',
    bullets: [
      'Reservas ilimitadas',
      'Hasta 15 usuarios',
      'PDF y Word con OCR',
      'Visa tracking + pasaportes',
      'Reportes financieros (MoM, comisiones)',
      'Soporte prioritario',
    ],
    cta: 'Empezar Profesional',
    highlight: true,
  },
];
---
<BaseLayout lang={lang} pageKey="pricing" title={title} description={description}>
  <section class="py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-extrabold text-brand-900">Precios simples, sin sorpresas.</h1>
      <p class="mt-4 text-lg text-gray-700">Todos los planes incluyen ingest IA, revisión humana, multi-idioma y respaldo de archivos originales.</p>
      <p class="mt-2 text-sm text-gray-500">Precios en MXN. Impuestos no incluidos. 14 días de prueba sin tarjeta.</p>
      <div class="mt-4 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-gray-600">
        <span class="flex items-center gap-1.5"><span class="text-accent-500">✓</span>14 días gratis</span>
        <span class="flex items-center gap-1.5"><span class="text-accent-500">✓</span>Sin plazos forzosos</span>
        <span class="flex items-center gap-1.5"><span class="text-accent-500">✓</span>Cancela en cualquier momento</span>
      </div>

      <div class="mt-8 inline-flex items-center gap-1 p-1 rounded-full bg-white border border-gray-200" id="billing-toggle">
        <button type="button" class="billing-toggle-btn px-4 py-2 rounded-full text-sm font-semibold transition-colors" data-billing="monthly">Mensual</button>
        <button type="button" class="billing-toggle-btn flex items-center gap-2 px-4 py-2 rounded-full text-sm font-semibold transition-colors" data-billing="annual">
          Anual
          <span class="text-[11px] font-bold text-white bg-accent-500 px-2 py-0.5 rounded-full whitespace-nowrap">2 meses gratis</span>
        </button>
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-2 gap-6">
      {plans.map(p => (
        <div class={`p-8 rounded-2xl bg-white border ${p.highlight ? 'border-accent-500 ring-2 ring-accent-500/30 shadow-lg' : 'border-gray-200'}`}>
          {p.highlight && <div class="text-xs font-bold uppercase tracking-wide text-brand-600 mb-2">Más popular</div>}
          <h3 class="text-2xl font-bold text-brand-900">{p.name}</h3>
          <p class="mt-1 text-sm text-gray-600">{p.audience}</p>
          <div class="mt-6" data-price-monthly>
            <div class="flex items-baseline gap-1">
              <span class="text-4xl font-extrabold text-brand-900">{p.price}</span>
              <span class="text-gray-600">{p.period} MXN</span>
            </div>
          </div>
          <div class="mt-6 hidden" data-price-annual>
            <div class="flex items-baseline gap-1">
              <span class="text-4xl font-extrabold text-brand-900">{p.annualPrice}</span>
              <span class="text-gray-600">/año MXN</span>
            </div>
            <p class="mt-1 text-sm text-gray-500">≈ {p.annualEquivalent}/mes · 2 meses gratis</p>
          </div>
          <ul class="mt-6 space-y-3 text-sm text-gray-700">
            {p.bullets.map(b => (
              <li class="flex gap-2"><span class="text-accent-500">✓</span>{b}</li>
            ))}
          </ul>
          <a href="https://rumbodesk.app" class={`mt-8 block text-center ${p.highlight ? 'btn-primary' : 'btn-ghost'}`}>{p.cta}</a>
        </div>
      ))}
    </div>
  </section>

  <section class="pb-14">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-gray-200 bg-white p-8">
        <h3 class="text-xl font-bold text-brand-900">Facturación y cumplimiento fiscal</h3>
        <p class="mt-3 text-gray-700 leading-relaxed">
          Todos nuestros servicios de software son facturados de forma 100% deducible en México a
          través de nuestra entidad legal constituida, Rumbo Tech Labs, S.A.S. de C.V.
          (RFC: RTL260323S44). Emitimos comprobantes fiscales digitales (CFDI 4.0) con la clave de
          uso del comprobante correspondiente a gastos en general (G03), aplicable a la
          adquisición de activos tecnológicos y servicios de software.
        </p>
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-gray-200 bg-paper p-8 text-center">
        <h3 class="text-xl font-bold text-brand-900">¿Agencia grande o necesidad específica?</h3>
        <p class="mt-2 text-gray-700">Si necesitas más usuarios, integraciones a la medida o un acuerdo distinto, lo armamos contigo.</p>
        <a href="/contacto" class="mt-5 inline-flex btn-ghost">Hablar con nosotros</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  function setBilling(mode: string) {
    document.querySelectorAll('[data-price-monthly]').forEach((el) => el.classList.toggle('hidden', mode !== 'monthly'));
    document.querySelectorAll('[data-price-annual]').forEach((el) => el.classList.toggle('hidden', mode !== 'annual'));
    document.querySelectorAll('.billing-toggle-btn').forEach((btn) => {
      const active = (btn as HTMLElement).dataset.billing === mode;
      btn.classList.toggle('bg-accent-500', active);
      btn.classList.toggle('text-white', active);
      btn.classList.toggle('text-brand-600', !active);
    });
  }
  document.querySelectorAll('.billing-toggle-btn').forEach((btn) => {
    btn.addEventListener('click', () => setBilling((btn as HTMLElement).dataset.billing || 'monthly'));
  });
  setBilling('monthly');
</script>
