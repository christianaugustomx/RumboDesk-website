---
import BaseLayout from '../layouts/BaseLayout.astro';
const lang = 'es' as const;
const title = 'Precios — RumboDesk · Planes desde $499 MXN al mes';
const description = 'Dos planes simples para operadores y agencias en LATAM. Esencial y Profesional. Precios en pesos mexicanos.';

const plans = [
  {
    name: 'Esencial',
    price: '$499',
    period: '/mes',
    audience: 'Operadores y agentes independientes que arrancan',
    bullets: [
      'Hasta 50 reservas al mes',
      'Ingest por email + pegado de texto',
      '2 usuarios',
      'Catálogo de proveedores ilimitado',
      'Soporte por email',
    ],
    cta: 'Empezar Esencial',
    highlight: false,
  },
  {
    name: 'Profesional',
    price: '$999',
    period: '/mes',
    audience: 'Agencias pequeñas y operadores en crecimiento',
    bullets: [
      'Reservas ilimitadas',
      'Hasta 15 usuarios',
      'PDF y Word con OCR',
      'Visa tracking + pasaportes',
      'Reportes financieros (MoM, comisiones)',
      'Soporte prioritario',
    ],
    cta: 'Empezar Profesional',
    highlight: true,
  },
];
---
<BaseLayout lang={lang} pageKey="pricing" title={title} description={description}>
  <section class="py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-extrabold text-brand-900">Precios simples, sin sorpresas.</h1>
      <p class="mt-4 text-lg text-gray-700">Todos los planes incluyen ingest IA, revisión humana, multi-idioma y respaldo de archivos originales.</p>
      <p class="mt-2 text-sm text-gray-500">Precios en MXN. Impuestos no incluidos. 14 días de prueba sin tarjeta.</p>
    </div>
  </section>

  <section class="pb-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-2 gap-6">
      {plans.map(p => (
        <div class={`p-8 rounded-2xl bg-white border ${p.highlight ? 'border-accent-500 ring-2 ring-accent-500/30 shadow-lg' : 'border-gray-200'}`}>
          {p.highlight && <div class="text-xs font-bold uppercase tracking-wide text-brand-600 mb-2">Más popular</div>}
          <h3 class="text-2xl font-bold text-brand-900">{p.name}</h3>
          <p class="mt-1 text-sm text-gray-600">{p.audience}</p>
          <div class="mt-6 flex items-baseline gap-1">
            <span class="text-4xl font-extrabold text-brand-900">{p.price}</span>
            <span class="text-gray-600">{p.period} MXN</span>
          </div>
          <ul class="mt-6 space-y-3 text-sm text-gray-700">
            {p.bullets.map(b => (
              <li class="flex gap-2"><span class="text-accent-500">✓</span>{b}</li>
            ))}
          </ul>
          <a href="https://rumbodesk.app" class={`mt-8 block text-center ${p.highlight ? 'btn-primary' : 'btn-ghost'}`}>{p.cta}</a>
        </div>
      ))}
    </div>
  </section>

  <section class="pb-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-gray-200 bg-paper p-8 text-center">
        <h3 class="text-xl font-bold text-brand-900">¿Agencia grande o necesidad específica?</h3>
        <p class="mt-2 text-gray-700">Si necesitas más usuarios, integraciones a la medida o un acuerdo distinto, lo armamos contigo.</p>
        <a href="/contacto" class="mt-5 inline-flex btn-ghost">Hablar con nosotros</a>
      </div>
    </div>
  </section>
</BaseLayout>
