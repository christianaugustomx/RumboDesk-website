---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Comparison from "../components/Comparison.astro";
import Steps from "../components/Steps.astro";
import Segments from "../components/Segments.astro";
import FounderProgram from "../components/FounderProgram.astro";
import Showcase from "../components/Showcase.astro";
import Faq from "../components/Faq.astro";
import FinalCta from "../components/FinalCta.astro";

const lang = "es" as const;
const title = "RumboDesk — El copiloto de IA para agencias de viaje en LATAM";
const description = "Deja de copiar y pegar. Reenvía emails, PDFs y notas de WhatsApp; RumboDesk los estructura como reservas en segundos. Revisión humana antes de confirmar.";
---

<BaseLayout lang={lang} pageKey="home" title={title} description={description}>
  <Hero lang={lang} />
  <Comparison lang={lang} />
  <Steps lang={lang} />
  <Segments lang={lang} />
  <FounderProgram lang={lang} />
  <Showcase lang={lang} />
  <Faq lang={lang} />
  <FinalCta lang={lang} />
</BaseLayout>
