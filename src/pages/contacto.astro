---
import BaseLayout from '../layouts/BaseLayout.astro';
const lang = 'es' as const;
const title = 'Contacto — RumboDesk';
const description = 'Hablemos. RumboDesk para operadores y agencias de viaje en LATAM.';
---
<BaseLayout lang={lang} pageKey="contact" title={title} description={description}>
  <section class="py-20">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl sm:text-5xl font-extrabold text-brand-900">Hablemos.</h1>
      <p class="mt-4 text-lg text-gray-700">Escríbenos para demos, consultas comerciales o soporte.</p>

      <div class="mt-8 space-y-4">
        <a href="mailto:hola@rumbodesk.com" class="block p-5 rounded-xl border border-gray-200 hover:border-brand-300 hover:bg-brand-50 transition">
          <div class="font-semibold text-brand-900">Email</div>
          <div class="text-gray-700">hola@rumbodesk.com</div>
        </a>
        <a href="https://wa.me/" class="block p-5 rounded-xl border border-gray-200 hover:border-brand-300 hover:bg-brand-50 transition">
          <div class="font-semibold text-brand-900">WhatsApp</div>
          <div class="text-gray-700">Próximamente</div>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
